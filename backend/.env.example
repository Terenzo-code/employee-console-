# Copy this file to .env and fill in real values. .env is gitignored on purpose —
# never commit real secrets.

# MongoDB connection string (MongoDB Atlas free tier works fine).
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/employeesDB?retryWrites=true&w=majority
DATABASE_URI=

# Random secrets used to sign JWTs. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use two DIFFERENT values — do not reuse one secret for both.
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Optional, defaults to 3500 if omitted
PORT=3500

# Set to "production" when deployed so cookies get secure:true (requires https).
# Leave unset (or "development") for local http development.
NODE_ENV=development
